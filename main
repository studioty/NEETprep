    }

    input {
      margin: 20px;
    }

    .card {
      background: #1e293b;
      padding: 20px;
      margin: 10px auto;
      width: 80%;
      border-radius: 10px;
      cursor: pointer;
    }

    .answer {
      display: none;
      color: #38bdf8;
      margin-top: 10px;
    }
  </style>
